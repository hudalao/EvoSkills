# Example SSH MCP Server Configuration for Remote GPU Execution
#
# This file demonstrates how to configure an SSH MCP server for remote
# GPU experiment execution with EvoScientist.
#
# Package: https://www.npmjs.com/package/mcp-server-ssh
#
# Usage:
# 1. Copy this file to ~/.config/evoscientist/mcp.yaml
# 2. Optionally set default credentials via env vars below
# 3. Start EvoScientist CLI or reload agent session
#
# NOTE: Credentials can also be provided per-connection via the
# ssh_connect tool call, so env vars below are optional defaults.

# ⚠️  SECURITY WARNING
# This gives the AI agent full, unsupervised access to the remote
# machine. Only connect to machines you fully control.

# SSH GPU server configuration
ssh-gpu:
  # Transport type (stdio for local MCP server process)
  transport: stdio

  # Command to start the MCP server
  command: npx

  # Arguments — pin version to prevent supply-chain attacks
  args:
    - "-y"
    - "mcp-server-ssh@1.0.2"

  # Optional environment variables for default credentials.
  # All are optional — the agent can provide credentials per-connection
  # via ssh_connect(host, username, privateKeyPath) tool calls.
  env:
    # Default SSH username (used when ssh_connect omits username)
    SSH_MCP_DEFAULT_USERNAME: "your-username"

    # Default private key path (auto-detects ed25519, rsa, ecdsa)
    # Default if unset: ~/.ssh/id_ed25519
    SSH_MCP_DEFAULT_KEY: "~/.ssh/id_ed25519"

    # Connection idle timeout in ms (default: 1800000 = 30 min)
    # SSH_MCP_IDLE_TIMEOUT: "1800000"

    # Default command execution timeout in ms (default: 30000 = 30s)
    # Increase for long-running GPU commands:
    # SSH_MCP_EXEC_TIMEOUT: "300000"

    # Max file size for sftp_read in bytes (default: 1048576 = 1MB)
    # SSH_MCP_MAX_FILE_SIZE: "10485760"

  # Which agents should have access to SSH tools
  expose_to:
    - code-agent
    - debug-agent

# Example: Multiple SSH servers for different GPU clusters
#
# gpu-cluster-1:
#   transport: stdio
#   command: npx
#   args: ["-y", "mcp-server-ssh@1.0.2"]
#   env:
#     SSH_MCP_DEFAULT_USERNAME: "alice"
#     SSH_MCP_DEFAULT_KEY: "~/.ssh/id_rsa_gpu1"
#   expose_to: [code-agent, debug-agent]
#
# gpu-cluster-2:
#   transport: stdio
#   command: npx
#   args: ["-y", "mcp-server-ssh@1.0.2"]
#   env:
#     SSH_MCP_DEFAULT_USERNAME: "bob"
#     SSH_MCP_DEFAULT_KEY: "~/.ssh/id_rsa_gpu2"
#   expose_to: [code-agent]
